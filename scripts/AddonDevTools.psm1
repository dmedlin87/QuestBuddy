function Write-GeneratedFile {
    param(
        [Parameter(Mandatory)]
        [string]$Path,

        [Parameter(Mandatory)]
        [string]$Content
    )

    $parent = Split-Path -Parent $Path
    if (-not [string]::IsNullOrWhiteSpace($parent)) {
        New-Item -ItemType Directory -Path $parent -Force | Out-Null
    }

    Set-Content -LiteralPath $Path -Value $Content -Encoding utf8
}

function Get-CurrentModulePath {
    $module = $MyInvocation.MyCommand.Module
    if ($null -eq $module -or [string]::IsNullOrWhiteSpace($module.Path)) {
        return $null
    }

    return $module.Path
}

function Sync-AddonToolchain {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$RepoRoot,

        [string]$SourceModulePath
    )

    $project = Resolve-AddonProject -RepoRoot $RepoRoot
    $generatedFiles = Get-ProjectGeneratedFileMap -Project $project

    if (-not $PSBoundParameters.ContainsKey("SourceModulePath")) {
        $SourceModulePath = Get-CurrentModulePath
        if ([string]::IsNullOrWhiteSpace($SourceModulePath)) {
            throw "SourceModulePath is required when the current module path cannot be determined."
        }
    }

    if (-not (Test-Path -LiteralPath $SourceModulePath -PathType Leaf)) {
        throw "Source module was not found at '$SourceModulePath'."
    }

    $project.Manifest.toolchainVersion = $script:AddonToolchainVersion
    Write-JsonFile -Path (Get-ProjectManifestPath -RepoRoot $project.RepoRoot) -Value $project.Manifest

    Copy-Item -LiteralPath $SourceModulePath -Destination $generatedFiles.ModulePath -Force
    Write-GeneratedFile -Path $generatedFiles.BuildScriptPath -Content (New-GeneratedBuildScriptContent)
    Write-GeneratedFile -Path $generatedFiles.ValidationScriptPath -Content (New-GeneratedValidationScriptContent)

    $installScriptName = [System.IO.Path]::GetFileName($generatedFiles.InstallScriptPath)
    Write-GeneratedFile -Path $generatedFiles.InstallScriptPath -Content (New-GeneratedInstallScriptContent)
    Write-GeneratedFile -Path $generatedFiles.InstallCmdPath -Content (New-GeneratedInstallCmdContent -InstallScriptName $installScriptName)

    if (Test-Path -LiteralPath $generatedFiles.LegacyModulePath -PathType Leaf) {
        Remove-Item -LiteralPath $generatedFiles.LegacyModulePath -Force
    }
}

function New-AddonProject {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$RepoRoot,

        [Parameter(Mandatory)]
        [string]$AddonId,

        [Parameter(Mandatory)]
        [string]$DisplayName,

        [string]$AddonFolder,

        [string]$Version = "0.1.0",

        [string[]]$TargetSupport = @("Bronzebeard", "CoA"),

        [string]$TocPath,

        [string]$TocContentRoot,

        [string]$DefaultWowPath = $script:DefaultWowPath,

        [string]$PtrWowPath = $script:DefaultPtrWowPath,

        [string]$VersionFilePath,

        [string]$CoverageScriptPath,

        [string[]]$CoverageArguments = @()
    )

    $resolvedRepoRoot = [System.IO.Path]::GetFullPath($RepoRoot)
    if ([string]::IsNullOrWhiteSpace($AddonFolder)) {
        $AddonFolder = $DisplayName
    }

    if ([string]::IsNullOrWhiteSpace($TocPath)) {
        $TocPath = Join-Path $AddonFolder ("{0}.toc" -f $AddonFolder)
    }

    if ([string]::IsNullOrWhiteSpace($TocContentRoot)) {
        $TocContentRoot = Split-Path -Parent $TocPath
        if ([string]::IsNullOrWhiteSpace($TocContentRoot)) {
            $TocContentRoot = "."
        }
    }

    New-Item -ItemType Directory -Path $resolvedRepoRoot -Force | Out-Null
    New-Item -ItemType Directory -Path (Join-Path $resolvedRepoRoot $TocContentRoot) -Force | Out-Null
    New-Item -ItemType Directory -Path (Join-Path $resolvedRepoRoot "scripts") -Force | Out-Null

    $manifest = [ordered]@{
        schemaVersion         = 2
        toolchainVersion      = $script:AddonToolchainVersion
        addonId               = $AddonId
        displayName           = $DisplayName
        version               = $Version
        targetSupport         = $TargetSupport
        folders               = @($AddonFolder)
        minInstallerVersion   = "1.0.0"
        defaultWowPath        = $DefaultWowPath
        ptrWowPath            = $PtrWowPath
        tocPath               = $TocPath
        tocContentRoot        = $TocContentRoot
        releaseOutputDir      = "release-assets"
        publishTimeoutSeconds = 120
    }

    if (-not [string]::IsNullOrWhiteSpace($VersionFilePath)) {
        $manifest.versionFilePath = $VersionFilePath
    }

    if (-not [string]::IsNullOrWhiteSpace($CoverageScriptPath)) {
        $manifest.coverageScriptPath = $CoverageScriptPath
    }

    if ($CoverageArguments.Count -gt 0) {
        $manifest.coverageArguments = $CoverageArguments
    }

    Write-JsonFile -Path (Get-ProjectManifestPath -RepoRoot $resolvedRepoRoot) -Value $manifest

    $tocAbsolutePath = [System.IO.Path]::GetFullPath((Join-Path $resolvedRepoRoot $TocPath))
    if (-not (Test-Path -LiteralPath $tocAbsolutePath -PathType Leaf)) {
        $tocContent = @(
            "## Interface: 11507"
            "## Title: $DisplayName"
            "## Version: $Version"
            ""
        ) -join "`n"
        Set-Content -LiteralPath $tocAbsolutePath -Value $tocContent -Encoding utf8
    }

    Sync-AddonToolchain -RepoRoot $resolvedRepoRoot -SourceModulePath (Get-CurrentModulePath)
}

Export-ModuleMember -Function Get-AddonToolchainInfo, Resolve-AddonProject, Invoke-AddonAction, Invoke-AddonRelease, Test-AddonProject, Sync-AddonToolchain, New-AddonProject
