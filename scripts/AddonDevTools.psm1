function Resolve-AddonProject {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$RepoRoot
    )

    $normalizedRepoRoot = Get-NormalizedRepoRoot -RepoRoot $RepoRoot
    $manifestPath = Get-ProjectManifestPath -RepoRoot $normalizedRepoRoot
    if (-not (Test-Path -LiteralPath $manifestPath -PathType Leaf)) {
        throw "Manifest file was not found at '$manifestPath'."
    }

    $manifest = Read-JsonFile -Path $manifestPath
    $project = [AddonProject]::new($normalizedRepoRoot, $manifest)
    Assert-AddonManifest -Project $project
    return $project
}

function Assert-AddonManifest {
    param(
        [Parameter(Mandatory)]
        [AddonProject]$Project
    )

    $schemaVersion = [int]$Project.Manifest.schemaVersion
    if ($schemaVersion -ne 2) {
        throw "Manifest schemaVersion must be 2."
    }

    $toolchainVersion = [string]$Project.Manifest.toolchainVersion
    if ([string]::IsNullOrWhiteSpace($toolchainVersion)) {
        throw "Manifest toolchainVersion is required."
    }

    if ($toolchainVersion -ne $script:AddonToolchainVersion) {
        throw "Manifest toolchainVersion '$toolchainVersion' does not match toolchain version '$($script:AddonToolchainVersion)'. Run Sync-AddonToolchain."
    }

    $addonId = Get-ProjectAddonId -Project $Project
    $displayName = Get-ProjectDisplayName -Project $Project
    $version = Get-ProjectVersion -Project $Project
    $folders = Get-ProjectAddonFolders -Project $Project
    $targetSupport = Get-ProjectTargetSupport -Project $Project
    $minInstallerVersion = Get-ProjectMinInstallerVersion -Project $Project
    $tocRelativePath = Get-ProjectTocRelativePath -Project $Project

    if ([string]::IsNullOrWhiteSpace($addonId) -or
        [string]::IsNullOrWhiteSpace($displayName) -or
        [string]::IsNullOrWhiteSpace($version) -or
        [string]::IsNullOrWhiteSpace($minInstallerVersion) -or
        [string]::IsNullOrWhiteSpace($tocRelativePath)) {
        throw "Manifest is missing one of: addonId, displayName, version, minInstallerVersion, tocPath."
    }

    if ($folders.Count -ne 1) {
        throw "Manifest must define exactly one managed folder."
    }

    if ($targetSupport.Count -eq 0) {
        throw "Manifest must define at least one supported target."
    }

    if (-not (Test-AddonSemVer -Value $version)) {
        throw "Version '$version' is not valid semver."
    }

    if (-not (Test-AddonSemVer -Value $minInstallerVersion)) {
        throw "minInstallerVersion '$minInstallerVersion' is not valid semver."
    }

    $publishTimeoutSeconds = Get-ProjectPublishTimeoutSeconds -Project $Project
    if ($publishTimeoutSeconds -lt 0) {
        throw "publishTimeoutSeconds must be zero or greater."
    }
}

function Assert-GeneratedFileMarker {
    param(
        [Parameter(Mandatory)]
        [string]$Path
    )

    if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
        throw "Generated file was not found at '$Path'."
    }

    $firstLine = Get-Content -LiteralPath $Path -TotalCount 1
    if ($firstLine -ne $script:GeneratedMarker -and $firstLine -ne $script:GeneratedCmdMarker) {
        throw "Generated file '$Path' is missing the expected marker. Run Sync-AddonToolchain."
    }
}

function Get-TocEntries {
    param(
        [Parameter(Mandatory)]
        [AddonProject]$Project
    )

    $tocPath = Get-ProjectTocPath -Project $Project
    if (-not (Test-Path -LiteralPath $tocPath -PathType Leaf)) {
        throw "Expected TOC file was not found at '$tocPath'."
    }

    $tocEntries = Get-Content -LiteralPath $tocPath |
        ForEach-Object { $_.Trim() } |
        Where-Object { $_ -and -not $_.StartsWith("##") -and -not $_.StartsWith("#") }

    if (-not $tocEntries) {
        throw "No runtime files were declared in '$tocPath'."
    }

    $result = @($tocEntries)
    return ,$result
}

function Get-TocVersion {
    param(
        [Parameter(Mandatory)]
        [AddonProject]$Project
    )

    $tocPath = Get-ProjectTocPath -Project $Project
    $tocVersionMatch = Select-String -Path $tocPath -Pattern '^## Version:\s*(.+)$'
    if (-not $tocVersionMatch) {
        throw "Unable to read addon version from '$tocPath'."
    }

    return $tocVersionMatch.Matches[0].Groups[1].Value.Trim()
}

function Set-TocVersion {
    param(
        [Parameter(Mandatory)]
        [AddonProject]$Project,

        [Parameter(Mandatory)]
        [string]$Version
    )

    $tocPath = Get-ProjectTocPath -Project $Project
    $tocContent = Get-Content -LiteralPath $tocPath -Raw
    if ($tocContent -notmatch '(?m)^## Version:\s*(.+)$') {
        throw "Unable to read addon version from '$tocPath'."
    }

    $updatedContent = [regex]::Replace($tocContent, '(?m)^## Version:\s*.+$', "## Version: $Version", 1)
    Set-Content -LiteralPath $tocPath -Value $updatedContent -Encoding utf8
}

function Read-VersionFileValue {
    param(
        [Parameter(Mandatory)]
        [AddonProject]$Project
    )

    $versionFilePath = Get-ProjectVersionFilePath -Project $Project
    if ($null -eq $versionFilePath) {
        return $null
    }

    if (-not (Test-Path -LiteralPath $versionFilePath -PathType Leaf)) {
        throw "Expected version file was not found at '$versionFilePath'."
    }

    $value = [string](Get-Content -LiteralPath $versionFilePath -Raw).Trim()
    if ([string]::IsNullOrWhiteSpace($value)) {
        throw "Version file '$versionFilePath' is empty."
    }

    return $value
}

