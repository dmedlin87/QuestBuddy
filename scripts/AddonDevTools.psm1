    AddonProject([string]$repoRoot, [pscustomobject]$manifest) {
        if ([string]::IsNullOrWhiteSpace($repoRoot)) {
            throw "RepoRoot is required."
        }

        if ($null -eq $manifest) {
            throw "Manifest is required."
        }

        $this.RepoRoot = $repoRoot
        $this.Manifest = $manifest
    }
}

